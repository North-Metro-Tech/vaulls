# Your Base wallet address to receive payments
VAULLS_PAY_TO=0xYOUR_WALLET_ADDRESS_HERE

# Network: "base-sepolia" for testnet, "base" for mainnet
VAULLS_NETWORK=base-sepolia

# CDP API keys (required — get them at https://portal.cdp.coinbase.com)
VAULLS_CDP_API_KEY_ID=your_cdp_api_key_id
VAULLS_CDP_API_KEY_SECRET=your_cdp_api_key_secret

# x402 facilitator URL (default: Coinbase CDP)
# VAULLS_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
